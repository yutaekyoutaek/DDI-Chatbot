USE_LLM=false
FACTCHAT_API_KEY=
FACTCHAT_BASE_URL=https://factchat-cloud.mindlogic.ai/v1/api/openai
FACTCHAT_MODEL=gpt-4o-mini

DDI_DATA_SOURCE=seed
DUR_ENABLED=false

# DUR OpenAPI settings
DUR_API_SERVICE_KEY=
DUR_API_BASE_URL=
DUR_API_OPERATION=
DUR_API_TIMEOUT=5

# query parameter names (Swagger 스펙에 맞춰 필요 시 수정)
DUR_API_SERVICE_KEY_PARAM=serviceKey
DUR_API_PAGE_NO_PARAM=pageNo
DUR_API_NUM_OF_ROWS_PARAM=numOfRows
DUR_API_TYPE_PARAM=type
DUR_API_DRUG_A_PARAM=itemNameA
DUR_API_DRUG_B_PARAM=itemNameB
DUR_API_RESPONSE_FORMAT=json

# response field names (Swagger 스펙에 맞춰 필요 시 수정)
DUR_API_RESPONSE_DRUG_A_FIELD=itemNameA
DUR_API_RESPONSE_DRUG_B_FIELD=itemNameB
DUR_API_RESPONSE_SEVERITY_FIELD=typeName
DUR_API_RESPONSE_SUMMARY_FIELD=prohbtContent
DUR_API_RESPONSE_RECOMMENDATION_FIELD=remark